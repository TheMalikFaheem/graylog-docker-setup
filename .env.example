# ─────────────────────────────────────────────────────────────────────────────
# Graylog Stack — Environment Variables
# Copy this file to .env and fill in your values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=graylog
MONGO_ROOT_PASSWORD=change_me_strong_password

# ── Graylog Security ───────────────────────────────────────────────────────────
# Generate with: pwgen -N 1 -s 96
GRAYLOG_PASSWORD_SECRET=replace_this_with_96_char_random_string_run_pwgen_dash_N_1_dash_s_96

# SHA256 hash of your desired admin password
# Generate with: echo -n "YourPassword" | sha256sum
# Default below is SHA256 of "admin" — CHANGE THIS!
GRAYLOG_ROOT_PASSWORD_SHA2=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# ── Web Access ─────────────────────────────────────────────────────────────────
# Set this to your server's public IP or domain if accessing remotely
GRAYLOG_HTTP_EXTERNAL_URI=http://localhost:9000/

# ── Timezone ───────────────────────────────────────────────────────────────────
GRAYLOG_TIMEZONE=UTC
